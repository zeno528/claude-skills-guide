---
// index.astro - 主页
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import WhatIsSkill from '../components/WhatIsSkill.astro';
import HowItWorks from '../components/HowItWorks.astro';
import CreateSkill from '../components/CreateSkill.astro';
import DesignSpecs from '../components/DesignSpecs.astro';
import OfficialSkills from '../components/OfficialSkills.astro';
import Examples from '../components/Examples.astro';
import BestPractices from '../components/BestPractices.astro';
import QuickReference from '../components/QuickReference.astro';
import Resources from '../components/Resources.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Header />
  <Hero />
  <WhatIsSkill />
  <HowItWorks />
  <CreateSkill />
  <DesignSpecs />
  <OfficialSkills />
  <Examples />
  <BestPractices />
  <QuickReference />
  <Resources />
  <Footer />

  <!-- 滚动动画初始化脚本 -->
  <script>
    // Section 进入动画 - 立即执行，确保在 DOM 加载后运行
    (function() {
      // 延迟执行以确保 DOM 完全渲染
      const initScrollAnimations = () => {
        const observerOptions = {
          threshold: 0.01,
          rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        const sections = document.querySelectorAll('.section-enter');
        sections.forEach(el => observer.observe(el));

        // 立即检查并显示已在视口中的元素
        // 这确保页面加载时可见的元素立即显示，而不需要等待 IntersectionObserver 回调
        const checkInitialVisibility = () => {
          sections.forEach(section => {
            const rect = section.getBoundingClientRect();
            const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
            if (isVisible && !section.classList.contains('visible')) {
              section.classList.add('visible');
            }
          });
        };

        // 立即检查一次
        checkInitialVisibility();
      };

      // 确保在 DOM 准备好后执行
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initScrollAnimations);
      } else {
        // 使用 setTimeout 确保在当前事件循环后执行
        setTimeout(initScrollAnimations, 0);
      }
    })();
  </script>
</BaseLayout>
