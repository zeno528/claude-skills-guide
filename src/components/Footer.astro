---
// Footer.astro - 页脚组件（简洁居中风格）
---

<footer class="py-16 px-4">
  <div class="max-w-4xl mx-auto text-center space-y-8">
    <!-- 标题 -->
    <h2 class="text-xl font-bold">
      Agent Skills Guide
    </h2>

    <!-- 外部资源链接 -->
    <div class="flex items-center justify-center gap-8 text-sm">
      <a
        href="https://github.com/Ekko7778/claude-skills-guide"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-claude-primary transition-colors inline-flex items-center gap-2 group"
      >
        <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>

      <span class="text-gray-600">|</span>

      <a
        href="https://code.claude.com/docs/en/overview"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-claude-secondary transition-colors inline-flex items-center gap-2 group"
      >
        <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
        官方文档
      </a>

      <span class="text-gray-600">|</span>

      <a
        href="https://support.anthropic.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-400 hover:text-claude-accent transition-colors inline-flex items-center gap-2 group"
      >
        <svg class="w-4 h-4 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        帮助中心
      </a>
    </div>

    <!-- 版权信息 -->
    <div class="pt-8 border-t border-white/10">
      <p class="text-xs text-gray-500">
        Built with
        <span class="text-claude-primary">♥</span>
        by the community
      </p>
    </div>
  </div>
</footer>
