---
// Particles.astro - 炫酷粒子特效组件（升级版）
// 特性：光晕效果、波浪流动、动态渐变、鼠标交互、闪烁效果
---

<!-- 粒子画布容器 -->
<div id="particles-container" class="particles-container">
  <canvas id="particles-canvas"></canvas>
  <canvas id="glow-canvas"></canvas>
</div>

<!-- 粒子特效样式 -->
<style>
  /* 粒子容器样式 */
  .particles-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0; /* 确保在所有内容后面 */
    pointer-events: none; /* 不影响鼠标事件 */
    overflow: hidden;
  }

  #particles-canvas,
  #glow-canvas {
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  /* 光晕画布在上层，但仍然在内容后面 - 适中透明度 */
  #glow-canvas {
    z-index: 1;
    opacity: 0.4; /* 适中的透明度 */
  }

  /* 粒子画布在底层 */
  #particles-canvas {
    z-index: 0;
  }

  /* 浅色主题下的粒子颜色调整 - 适度降低 */
  html:not(.dark) #glow-canvas {
    opacity: 0.25; /* 浅色模式下适度降低 */
  }
</style>

<!-- 粒子特效脚本 -->
<script is:inline>
  // ========== 炫酷粒子系统配置 ==========
  const PARTICLE_CONFIG = {
    // 粒子数量（根据屏幕大小自适应）- 适度数量
    particleCount: window.innerWidth < 768 ? 40 : 70,

    // 粒子大小范围 - 适中尺寸
    minSize: 1.2,
    maxSize: 2.5,

    // 粒子移动速度 - 适中速度
    minSpeed: 0.25,
    maxSpeed: 0.6,

    // 连线距离 - 适度连线
    lineDistance: 110,

    // 鼠标交互距离 - 适度交互
    mouseDistance: 140,

    // 鼠标引力力度（负值=排斥，正值=吸引）- 适中力度
    mouseForce: -2,

    // 波浪效果参数 - 适中振幅
    waveAmplitude: 0.3,      // 波浪振幅
    waveFrequency: 0.002,    // 波浪频率
    waveSpeed: 0.009,         // 波浪速度

    // 闪烁效果 - 适度闪烁
    twinkleChance: 0.003,    // 闪烁概率
    twinkleSpeed: 0.04,      // 闪烁速度

    // 光晕效果 - 适中强度
    glowSize: 10,            // 光晕大小
    glowIntensity: 0.18,     // 光晕强度

    // 渐变色配置（深色主题）
    colors: {
      primary: { r: 99, g: 102, b: 241 },      // 紫色
      secondary: { r: 139, g: 92, b: 246 },    // 紫罗兰色
      accent: { r: 245, g: 158, b: 11 },       // 橙色
      cyan: { r: 34, g: 211, b: 238 },         // 青色（新增）
      pink: { r: 244, g: 114, b: 182 }         // 粉色（新增）
    },

    // 浅色主题颜色
    lightColors: {
      primary: { r: 79, g: 70, b: 229 },
      secondary: { r: 124, g: 58, b: 237 },
      accent: { r: 217, g: 119, b: 6 },
      cyan: { r: 6, g: 182, b: 212 },
      pink: { r: 219, g: 39, b: 119 }
    }
  };

  // ========== 粒子类（增强版） ==========
  class Particle {
    constructor(canvas, glowCanvas, isLightMode = false) {
      this.canvas = canvas;
      this.ctx = canvas.getContext('2d');
      this.glowCtx = glowCanvas.getContext('2d');
      this.isLightMode = isLightMode;

      // 初始化位置
      this.x = Math.random() * canvas.width;
      this.y = Math.random() * canvas.height;

      // 基础速度
      this.baseSpeedX = (Math.random() - 0.5) * PARTICLE_CONFIG.maxSpeed * 2;
      this.baseSpeedY = (Math.random() - 0.5) * PARTICLE_CONFIG.maxSpeed * 2;

      // 当前速度（会被波浪和鼠标影响）
      this.speedX = this.baseSpeedX;
      this.speedY = this.baseSpeedY;

      // 大小
      this.size = Math.random() * (PARTICLE_CONFIG.maxSize - PARTICLE_CONFIG.minSize) + PARTICLE_CONFIG.minSize;

      // 颜色
      const colorSet = isLightMode ? PARTICLE_CONFIG.lightColors : PARTICLE_CONFIG.colors;
      const colorKeys = Object.keys(colorSet);
      this.color = colorSet[colorKeys[Math.floor(Math.random() * colorKeys.length)]];

      // 透明度 - 适中的基础透明度
      this.opacity = Math.random() * 0.25 + 0.2; // 0.2 ~ 0.45（适中）
      this.baseOpacity = this.opacity;

      // 闪烁相关
      this.isTwinkling = false;
      this.twinklePhase = 0;

      // 波浪相位（每个粒子不同，创造自然效果）
      this.wavePhase = Math.random() * Math.PI * 2;

      // 鼠标影响
      this.mouseVelocityX = 0;
      this.mouseVelocityY = 0;
    }

    // 更新粒子状态
    update(mouse, time) {
      // ========== 波浪效果 ==========
      // 使用正弦波创造流动的有机运动
      const waveX = Math.sin(time * PARTICLE_CONFIG.waveSpeed + this.wavePhase) * PARTICLE_CONFIG.waveAmplitude;
      const waveY = Math.cos(time * PARTICLE_CONFIG.waveSpeed + this.wavePhase * 0.7) * PARTICLE_CONFIG.waveAmplitude;

      this.speedX = this.baseSpeedX + waveX;
      this.speedY = this.baseSpeedY + waveY;

      // ========== 鼠标交互（增强版） ==========
      if (mouse.x !== null && mouse.y !== null) {
        const dx = mouse.x - this.x;
        const dy = mouse.y - this.y;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < PARTICLE_CONFIG.mouseDistance) {
          const force = (1 - distance / PARTICLE_CONFIG.mouseDistance);
          const directionX = dx / distance;
          const directionY = dy / distance;

          // 应用排斥力（负力值）或吸引力（正力值）
          const forceStrength = force * Math.abs(PARTICLE_CONFIG.mouseForce);
          this.mouseVelocityX -= directionX * forceStrength;
          this.mouseVelocityY -= directionY * forceStrength;
        }
      }

      // 鼠标影响的衰减（平滑恢复）
      this.mouseVelocityX *= 0.95;
      this.mouseVelocityY *= 0.95;

      // ========== 闪烁效果 ==========
      if (!this.isTwinkling && Math.random() < PARTICLE_CONFIG.twinkleChance) {
        this.isTwinkling = true;
        this.twinklePhase = 0;
      }

      if (this.isTwinkling) {
        this.twinklePhase += PARTICLE_CONFIG.twinkleSpeed;
        // 使用正弦波创造平滑的闪烁效果 - 适中闪烁幅度
        this.opacity = this.baseOpacity + Math.sin(this.twinklePhase) * 0.15;

        // 闪烁结束
        if (this.twinklePhase > Math.PI) {
          this.isTwinkling = false;
          this.opacity = this.baseOpacity;
        }
      }

      // ========== 更新位置 ==========
      this.x += this.speedX + this.mouseVelocityX;
      this.y += this.speedY + this.mouseVelocityY;

      // ========== 边界处理（环绕） ==========
      if (this.x < -this.size * 2) this.x = this.canvas.width + this.size;
      if (this.x > this.canvas.width + this.size * 2) this.x = -this.size;
      if (this.y < -this.size * 2) this.y = this.canvas.height + this.size;
      if (this.y > this.canvas.height + this.size * 2) this.y = -this.size;
    }

    // 绘制粒子
    draw() {
      // 绘制粒子本体
      this.ctx.beginPath();
      this.ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      this.ctx.fillStyle = `rgba(${this.color.r}, ${this.color.g}, ${this.color.b}, ${this.opacity})`;
      this.ctx.fill();

      // 绘制光晕（在 glowCanvas 上）
      this.drawGlow();
    }

    // 绘制光晕效果
    drawGlow() {
      const gradient = this.glowCtx.createRadialGradient(
        this.x, this.y, 0,
        this.x, this.y, PARTICLE_CONFIG.glowSize
      );

      gradient.addColorStop(0, `rgba(${this.color.r}, ${this.color.g}, ${this.color.b}, ${PARTICLE_CONFIG.glowIntensity * this.opacity})`);
      gradient.addColorStop(0.4, `rgba(${this.color.r}, ${this.color.g}, ${this.color.b}, ${PARTICLE_CONFIG.glowIntensity * this.opacity * 0.5})`);
      gradient.addColorStop(1, 'rgba(0, 0, 0, 0)');

      this.glowCtx.beginPath();
      this.glowCtx.arc(this.x, this.y, PARTICLE_CONFIG.glowSize, 0, Math.PI * 2);
      this.glowCtx.fillStyle = gradient;
      this.glowCtx.fill();
    }
  }

  // ========== 粒子系统管理器（升级版） ==========
  class ParticleSystem {
    constructor() {
      this.canvas = document.getElementById('particles-canvas');
      this.ctx = this.canvas.getContext('2d');
      this.glowCanvas = document.getElementById('glow-canvas');
      this.glowCtx = this.glowCanvas.getContext('2d');
      this.particles = [];
      this.mouse = { x: null, y: null };
      this.isLightMode = !document.documentElement.classList.contains('dark');
      this.time = 0;

      this.init();
      this.setupEventListeners();
      this.animate();
    }

    init() {
      this.resize();

      // 创建粒子
      this.particles = [];
      for (let i = 0; i < PARTICLE_CONFIG.particleCount; i++) {
        this.particles.push(new Particle(this.canvas, this.glowCanvas, this.isLightMode));
      }
    }

    setupEventListeners() {
      // 窗口大小变化
      window.addEventListener('resize', () => {
        this.resize();
        this.init();
      });

      // 鼠标移动
      window.addEventListener('mousemove', (e) => {
        this.mouse.x = e.clientX;
        this.mouse.y = e.clientY;
      });

      // 鼠标离开
      window.addEventListener('mouseout', () => {
        this.mouse.x = null;
        this.mouse.y = null;
      });

      // 主题变化监听
      const observer = new MutationObserver(() => {
        const wasLightMode = this.isLightMode;
        this.isLightMode = !document.documentElement.classList.contains('dark');

        if (wasLightMode !== this.isLightMode) {
          this.init();
        }
      });

      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class']
      });
    }

    resize() {
      this.canvas.width = window.innerWidth;
      this.canvas.height = window.innerHeight;
      this.glowCanvas.width = window.innerWidth;
      this.glowCanvas.height = window.innerHeight;

      // 根据屏幕大小调整粒子数量 - 适度数量
      PARTICLE_CONFIG.particleCount = window.innerWidth < 768 ? 40 : 70;
    }

    // 绘制动态连线
    drawLines() {
      for (let i = 0; i < this.particles.length; i++) {
        for (let j = i + 1; j < this.particles.length; j++) {
          const dx = this.particles[i].x - this.particles[j].x;
          const dy = this.particles[i].y - this.particles[j].y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < PARTICLE_CONFIG.lineDistance) {
            // 动态透明度（距离越近越亮）- 适中透明度
            const opacity = (1 - distance / PARTICLE_CONFIG.lineDistance) * 0.12; // 适中的透明度

            // 创建渐变连线
            const gradient = this.ctx.createLinearGradient(
              this.particles[i].x, this.particles[i].y,
              this.particles[j].x, this.particles[j].y
            );

            const color1 = this.particles[i].color;
            const color2 = this.particles[j].color;

            gradient.addColorStop(0, `rgba(${color1.r}, ${color1.g}, ${color1.b}, ${opacity})`);
            gradient.addColorStop(1, `rgba(${color2.r}, ${color2.g}, ${color2.b}, ${opacity})`);

            this.ctx.beginPath();
            this.ctx.strokeStyle = gradient;
            this.ctx.lineWidth = 0.8;
            this.ctx.moveTo(this.particles[i].x, this.particles[i].y);
            this.ctx.lineTo(this.particles[j].x, this.particles[j].y);
            this.ctx.stroke();
          }
        }
      }
    }

    animate() {
      // 更新时间
      this.time += 1;

      // 清空画布
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
      this.glowCtx.clearRect(0, 0, this.glowCanvas.width, this.glowCanvas.height);

      // 更新和绘制粒子
      this.particles.forEach(particle => {
        particle.update(this.mouse, this.time);
        particle.draw();
      });

      // 绘制连线
      this.drawLines();

      // 继续动画
      requestAnimationFrame(() => this.animate());
    }
  }

  // ========== 初始化粒子系统 ==========
  if (typeof window !== 'undefined') {
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        new ParticleSystem();
      });
    } else {
      new ParticleSystem();
    }
  }
</script>
