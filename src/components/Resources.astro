---
// Resources.astro - "相关资源" 区域
---

<section class="py-20 px-4">
  <div class="max-w-4xl mx-auto section-enter">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold mb-4">相关资源</h2>
      <p class="text-gray-400">深入学习 Agent Skills</p>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <a href="https://github.com/anthropics/skills" target="_blank" rel="noopener noreferrer" class="glass-card rounded-2xl p-6 hover:border-claude-primary/50 transition-colors group">
        <div class="flex items-center gap-4 mb-3">
          <svg class="w-8 h-8 text-gray-400 group-hover:text-claude-primary transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          <div>
            <h4 class="font-bold">anthropic/skills</h4>
            <p class="text-sm text-gray-400">官方 Skills 仓库</p>
          </div>
        </div>
        <p class="text-sm text-gray-500">16 个生产级 Skills 参考实现</p>
      </a>
      <a href="https://code.claude.com/docs/en/skills" target="_blank" rel="noopener noreferrer" class="glass-card rounded-2xl p-6 hover:border-claude-accent/50 transition-colors group">
        <div class="flex items-center gap-4 mb-3">
          <svg class="w-8 h-8 text-gray-400 group-hover:text-claude-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <div>
            <h4 class="font-bold">Claude Code 文档</h4>
            <p class="text-sm text-gray-400">code.claude.com</p>
          </div>
        </div>
        <p class="text-sm text-gray-500">官方使用指南</p>
      </a>
      <a href="https://anthropic.com/engineering/equipping-agents-for-the-real-world-with-agent-skills" target="_blank" rel="noopener noreferrer" class="glass-card rounded-2xl p-6 hover:border-claude-success/50 transition-colors group">
        <div class="flex items-center gap-4 mb-3">
          <svg class="w-8 h-8 text-gray-400 group-hover:text-claude-success transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <div>
            <h4 class="font-bold">工程博客</h4>
            <p class="text-sm text-gray-400">anthropic.com</p>
          </div>
        </div>
        <p class="text-sm text-gray-500">Agent Skills 设计理念</p>
      </a>
      <a href="https://github.com/anthropics/skills/blob/main/template/SKILL.md" target="_blank" rel="noopener noreferrer" class="glass-card rounded-2xl p-6 hover:border-claude-secondary/50 transition-colors group">
        <div class="flex items-center gap-4 mb-3">
          <svg class="w-8 h-8 text-gray-400 group-hover:text-claude-secondary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <div>
            <h4 class="font-bold">官方模板</h4>
            <p class="text-sm text-gray-400">GitHub</p>
          </div>
        </div>
        <p class="text-sm text-gray-500">快速开始创建 Skill</p>
      </a>
    </div>
  </div>
</section>
